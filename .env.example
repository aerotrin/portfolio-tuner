# ------------------------------------------------------------------------------
# Portfolio Tuner - combined .env.example (backend + frontend)
# Copy to .env and fill in values. Use from repo root for Docker Compose or uv.
# Defaults for local development. For Docker Compose, see docker-compose.yml.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Backend (FastAPI)
# ------------------------------------------------------------------------------

PROJECT_NAME=PortfolioTunerAPI
BACKEND_URL=http://127.0.0.1:8000 # Docker Compose: http://backend:8000
API_PREFIX=/api/v1 
ADMIN_ENABLED=false

# PostgreSQL Database (required)
# POSTGRES_URL: Dashboard → Settings → Database → Connection string → URI (Session mode)
POSTGRES_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase auth (required for authentication) 
# SUPABASE_URL: Dashboard → Settings → API → Project URL
# SUPABASE_KEY: Dashboard → Settings → API → anon/public key
# SUPABASE_JWT_PUBLIC_KEY: Dashboard → Settings → API → JWT Settings → JWKS → copy the JWK object
#   Paste the JWK as a single-line JSON string, e.g.:
#   SUPABASE_JWT_PUBLIC_KEY={"kty":"EC","crv":"P-256","x":"...","y":"...","alg":"ES256","key_ops":["verify"]}
SUPABASE_URL=EnterSupabaseURLHere
SUPABASE_KEY=EnterSupabaseAnonKeyHere
SUPABASE_JWT_PUBLIC_KEY=EnterJWKJsonHere

# Market Data Providers
# By default yfinance is used as the primary datasource (no API key required).
MAX_CONCURRENCY=5 # limits concurrent requests to market data providers
# Set ENABLE_FMP_AS_PRIMARY=true to use FMP as primary with yfinance as backup.
ENABLE_FMP_AS_PRIMARY=false

# FMP API Settings (required only when ENABLE_FMP_AS_PRIMARY=true)
FMP_API_KEY=EnterAPIKeyHere
FMP_RATE_LIMIT=100 # max requests per minute, based on plan limit

# ------------------------------------------------------------------------------
# Frontend (Streamlit)
# ------------------------------------------------------------------------------

DEBUG=false # Use DEBUG=true for local development

# Timeouts (seconds)
CONNECT_TIMEOUT=5 # connection timeout to backend API
READ_TIMEOUT=30 # read timeout to backend API

# Refresh intervals (milliseconds)
APP_REFRESH_INTERVAL=0 # streamlit app refresh interval, 0 means no refresh

